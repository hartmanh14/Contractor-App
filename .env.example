# Copy this file to .env and fill in your values
# Never commit .env to git

# Google Places API — enables live contractor search
# Get a key at https://console.cloud.google.com/ (Places API must be enabled)
VITE_GOOGLE_PLACES_API_KEY=

# Stripe — for future billing/subscription features
VITE_STRIPE_PUBLISHABLE_KEY=

# App config
VITE_APP_NAME=BuildBoss
VITE_APP_URL=http://localhost:3000
