# Copy this file to .env and fill in your values
# Never commit .env to git

# ---- Backend (server/index.mjs) ---------------------------------------------

# Anthropic API key — powers all /api/analyze*, /api/analyze-trade, and
# /api/review-contract endpoints. Without this the frontend automatically
# falls back to local mock data, but the real trade-specialist agents will
# not run. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key — optional. When set, the backend generates DALL-E 3
# renderings of each design option. Without it, analysis still runs but
# `imageUrl` fields will be null. Get a key at https://platform.openai.com/
OPENAI_API_KEY=

# Server port (defaults to 3001 locally; Render injects its own PORT)
PORT=3001

# ---- Frontend (Vite) --------------------------------------------------------

# Google Places API — enables live contractor search
# Get a key at https://console.cloud.google.com/ (Places API must be enabled)
VITE_GOOGLE_PLACES_API_KEY=

# Stripe — for future billing/subscription features
VITE_STRIPE_PUBLISHABLE_KEY=

# App config
VITE_APP_NAME=BuildBoss
VITE_APP_URL=http://localhost:3000
